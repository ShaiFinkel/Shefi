{
  "name": "shefi-and-co",
  "version": "0.1.0",
  "description": "Shefi & Co. — חברת סוכני AI אישית בטלגרם",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build:server": "tsc",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:server && npm run build:frontend",
    "start": "npm run build && node dist/index.js",
    "start:fast": "node dist/index.js",
    "frontend:dev": "cd frontend && npm run dev",
    "db:init": "tsc && node dist/db/init.js",
    "typecheck": "tsc --noEmit",
    "qa:email-approval": "node scripts/qa-email-approval.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@openai/agents": "^0.10.0",
    "better-sqlite3": "^12.9.0",
    "cookie": "^1.1.1",
    "dotenv": "^17.4.2",
    "eventemitter3": "^5.0.4",
    "fastify": "^5.8.5",
    "grammy": "^1.42.0",
    "node-cron": "^4.2.1",
    "openai": "^6.36.0",
    "resend": "^6.12.3",
    "simple-git": "^3.36.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
