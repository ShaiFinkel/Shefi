# העתיקי לקובץ .env ומלאי ערכים. לעולם אל תכניסי .env ל־git.

# --- Telegram (חובה) ---
# Token מ־@BotFather
TELEGRAM_BOT_TOKEN=

# רשימה מופרדת בפסיקים של Telegram user IDs שמורשים להשתמש בבוט (מספרים).
# השיגי את שלך מ־@userinfobot
TELEGRAM_ALLOWED_USER_IDS=

# --- OpenAI (חובה) ---
# מפתח מ־https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- מודלים (אופציונלי) ---
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_SMART=gpt-4o
OPENAI_MODEL_TRANSCRIBE=whisper-1
OPENAI_MODEL_EMBEDDING=text-embedding-3-small

# --- אזור זמן לדייג'סטים והתזכורות ---
TZ=Asia/Jerusalem

# --- מיקום קובץ DB (אופציונלי) ---
DB_PATH=./data/shefi.db

# --- כתובת ציבורית של האפליקציה (להופעה במיילים של magic link) ---
# בפיתוח: השאירי על localhost. בפרודקשן: הכניסי את הדומיין שלך, למשל https://shefi.team
APP_PUBLIC_URL=http://localhost:3000

# --- שירות מייל (Resend) ---
# הירשמי בחינם ב־https://resend.com/api-keys והדביקי כאן.
# אם ריק — magic links יודפסו בקונסול במקום (מצב dev).
RESEND_API_KEY=
RESEND_FROM_EMAIL=Shefi & Co. <onboarding@resend.dev>

# --- הגנת אדמין על הדשבורד ---
# מחרוזת אקראית כלשהי. שמורה ב־localStorage של הדפדפן שלך כדי שרק
# דפדפנים שאישרת ידנית יוכלו לגשת ל־endpoints ניהוליים.
# ריק = ללא הגנה (גישה פתוחה ברשת המקומית).
ADMIN_TOKEN=

# --- Web Push (VAPID keys) ---
# יצירת מפתחות חד-פעמית: npx web-push generate-vapid-keys
# אם ריקים — התראות Push כבויות שקטות.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:shai@example.com
