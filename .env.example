# העתיקי לקובץ .env ומלאי ערכים. לעולם אל תכניסי .env ל־git.

# --- Telegram (חובה) ---
# Token מ־@BotFather
TELEGRAM_BOT_TOKEN=

# רשימה מופרדת בפסיקים של Telegram user IDs שמורשים להשתמש בבוט (מספרים).
# השיגי את שלך מ־@userinfobot
TELEGRAM_ALLOWED_USER_IDS=

# --- OpenAI (חובה) ---
# מפתח מ־https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- מודלים (אופציונלי) ---
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_SMART=gpt-4o
OPENAI_MODEL_TRANSCRIBE=whisper-1
OPENAI_MODEL_EMBEDDING=text-embedding-3-small

# --- אזור זמן לדייג'סטים והתזכורות ---
TZ=Asia/Jerusalem

# --- מיקום קובץ DB (אופציונלי) ---
DB_PATH=./data/shefi.db
