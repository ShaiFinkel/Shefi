# Copy to .env and fill in. Never commit .env.

# Required: from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to create tasks (integers).
# Get yours from @userinfobot on Telegram.
TELEGRAM_ALLOWED_USER_IDS=

# Optional: map if your Airtable field for Telegram id differs
# FIELD_TELEGRAM_MESSAGE_ID=Telegram message id

# --- Airtable (optional; if unset, tasks append to data/tasks.jsonl) ---
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
# Table name exactly as in Airtable UI
AIRTABLE_TASKS_TABLE=Tasks

# Field names must match your Airtable Tasks table (see docs/airtable-schema.md)
FIELD_TITLE=Title
FIELD_DETAILS=Details
FIELD_DUE_DATE=Due date
FIELD_STATUS=Status
FIELD_PRIORITY=Priority
FIELD_SOURCE=Source

# Defaults for new tasks
DEFAULT_STATUS=Todo
DEFAULT_PRIORITY=P3
SOURCE_VALUE=telegram
